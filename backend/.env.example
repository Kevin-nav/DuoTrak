# PostgreSQL Database URL
# Example for local Docker: DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/duotrak_db"
DATABASE_URL=

# Firebase Service Account
# For local dev, path to the JSON file. For prod, the JSON content as a string.
FIREBASE_SERVICE_ACCOUNT_JSON_PATH="./duotrak-6367d-firebase-adminsdk-fbsvc-fee690a079.json"

# Redis URL for Rate Limiting (Upstash)
# Example: REDIS_URL="redis://default:password@host:port"
REDIS_URL=

# Resend API Key for sending emails
RESEND_API_KEY=
ENVIRONMENT=development
CLIENT_ORIGIN_URL="http://localhost:3000"

# Application Settings
PROJECT_NAME="DuoTrak API"
DATABASE_URL=postgresql://user:password@localhost/db_name
SECRET_KEY=your_secret_key
API_V1_STR=/api/v1
PROJECT_NAME=DuoTrak
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
