# ==============================================================================
# Required backend runtime settings
# ==============================================================================
ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:54322/postgres
CLIENT_ORIGIN_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=
INTERNAL_API_SECRET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=duotrak
GEMINI_API_KEY=
PINECONE_API_KEY=

# ==============================================================================
# Optional backend runtime settings
# ==============================================================================
PINECONE_INDEX_NAME=duotrak-user-model-data
PROJECT_NAME=DuoTrak API
API_V1_STR=/api/v1
BACKEND_CORS_ORIGINS=["http://127.0.0.1:3000"]
SESSION_COOKIE_NAME=__session
FLASH_MODEL=gemini-3-flash-preview
PRO_MODEL=gemini-2.5-pro
DEFAULT_THINKING_BUDGET=8000
MAX_THINKING_BUDGET=32000
ENABLE_EXTERNAL_EVALUATION=true
TEST_DATASET_PATH=data/holistic_test_dataset.json
HISTORICAL_SNAPSHOT_WEEKS=4
GOAL_CREATION_SESSION_TTL_SECONDS=900
GOAL_CREATION_ALLOW_IN_MEMORY_SESSION_FALLBACK=false
GOAL_CHAT_SESSION_TTL_SECONDS=1800
GOAL_CHAT_AI_ENABLED=true
GOAL_QUESTIONS_TIMEOUT_SECONDS=30
AI_ORCHESTRATOR=crewai
AI_SHADOW_MODE=false
AI_SHADOW_ORCHESTRATOR=langgraph
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
CONVEX_LEDGER_ENDPOINT=
CONVEX_LEDGER_SECRET=
