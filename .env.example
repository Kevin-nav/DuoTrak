# ==============================================================================
# Public Environment Variables
# ==============================================================================
# These variables are exposed to the browser and are prefixed with NEXT_PUBLIC_.
# This should be the root URL of your FastAPI backend.
# For local development, this will be http://127.0.0.1:8000
# For production, this will be the URL of your deployed Google Cloud Run service.
NEXT_PUBLIC_API_BASE_URL=


# ==============================================================================
# Firebase Admin SDK Credentials
# ==============================================================================
# The application uses a path to your Firebase service account JSON file.
# This is the most robust method for providing credentials.
# The path should be relative to the root of the project directory.
FIREBASE_SERVICE_ACCOUNT_JSON_PATH="./firebase-adminsdk.json"


# ==============================================================================
# Backend and API Keys
# ==============================================================================

# The full URL of your running FastAPI backend.
# For local development, this is typically http://localhost:8000
FASTAPI_URL=

# This is a shared secret used to secure the server-to-server communication
# between the Next.js and FastAPI backends. It must be at least 32 characters long.
# IMPORTANT: This value MUST be identical to the SECRET_KEY in the backend's .env file.
SECRET_KEY=


# ==============================================================================
# Other Services
# ==============================================================================

# PostgreSQL Database URL
# Example for local Docker: DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/duotrak_db"
DATABASE_URL=

# Redis URL for Rate Limiting (Upstash)
# Example: REDIS_URL="redis://default:password@host:port"
REDIS_URL=

# Resend API Key for sending emails
RESEND_API_KEY=
